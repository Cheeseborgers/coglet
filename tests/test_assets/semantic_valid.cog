Color :: enum(u16) {
    Red,
    Green,
    Blue,
}

ErrorCode :: enum(i32) {
    None = 0,
    File = 10,
    Parse,
}

Flags :: enum(u8) {
    Read = 1,
    Write = 2,
    Execute = 4,
}

favorite: Color = Color.Red;

other_color := Color.Green;

Color.Red == Color.Blue;
Color.Red != Color.Green;

use_color::(c: Color) -> Color {
    return Color.Blue;
}

result_color := use_color(Color.Red);

DEFAULT_COLOR :: Color.Red;

favorite1: Color = DEFAULT_COLOR;

EXPLICIT_COLOR: Color : Color.Blue;

other: Color = EXPLICIT_COLOR;

classify_color::(c: Color) -> i32 {
    switch c {
        case Color.Red:
            return 1;

        case Color.Green:
            return 2;

        case Color.Blue:
            return 3;

        default:
            return 0;
    }
}

classify_int::(x: i32) -> i32 {
    switch x {
        case 0:
            return 10;

        case 1:
            return 20;

        default:
            return 30;
    }
}

classify_bool::(b: bool) -> i32 {
    switch b {
        case true:
            return 1;

        case false:
            return 0;
    }
}

return_good_direct::() -> i32 {
    return 1;
}

return_good_if::(b: bool) -> i32 {
    if b {
        return 1;
    } else {
        return 2;
    }
}

return_good_switch::(c: Color) -> i32 {
    switch c {
        case Color.Red:
            return 1;

        default:
            return 0;
    }
}

cast_source: i32 = 10;

cast_i64_test: i64 = cast(i64, cast_source);

cast_color_test: Color = cast(Color, 0);

cast_enum_raw_test: u16 = cast(u16, Color.Green);

cast_i32_to_i64::() -> i64 {
    small: i32 = 10;
    return cast(i64, small);
}

cast_float_to_int::() -> i32 {
    return cast(i32, 3.14);
}

cast_enum_to_int::() -> u16 {
    return cast(u16, Color.Green);
}

cast_int_to_enum::() -> Color {
    return cast(Color, 0);
}

CAST_CONST_INT :: cast(i32, 10);
CAST_CONST_COLOR :: cast(Color, 1);

cast_const_use: Color = CAST_CONST_COLOR;

classify_color_exhaustive::(c: Color) -> i32 {
