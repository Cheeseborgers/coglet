Color :: enum(u16) {
    Red,
    Green,
    Blue,
}

ErrorCode :: enum(i32) {
    None = 0,
    File = 10,
    Parse,
}

Flags :: enum(u8) {
    Read = 1,
    Write = 2,
    Execute = 4,
}

favorite: Color = Color.Red;

other_color := Color.Green;

Color.Red == Color.Blue;
Color.Red != Color.Green;

use_color::(c: Color) -> Color {
    return Color.Blue;
}

result_color := use_color(Color.Red);

DEFAULT_COLOR :: Color.Red;

favorite1: Color = DEFAULT_COLOR;

EXPLICIT_COLOR: Color : Color.Blue;

other: Color = EXPLICIT_COLOR;

classify_color::(c: Color) -> i32 {
    switch c {
        case Color.Red:
            return 1;

        case Color.Green:
            return 2;

        case Color.Blue:
            return 3;

        default:
            return 0;
    }
}