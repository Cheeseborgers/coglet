LEFT_U8: u8 :
    cast(u8, 128) << 1;

LEFT_I8: i8 :
    cast(i8, 64) << 1;

RIGHT_U8: u8 :
    cast(u8, 128) >> 1;

RIGHT_I8_NEGATIVE: i8 :
    cast(i8, -3) >> 1;

RIGHT_I8_MIN: i8 :
    cast(i8, -128) >> 7;

ZERO_SHIFT: i32 :
    123 << 0;

UNTYPED_LEFT: i32 :
    1 << 3;

COUNT_EXPRESSION: u16 :
    cast(u16, 1) << (2 + 1);

NAMED_COUNT :: 3;

NAMED_SHIFT: u32 :
    cast(u32, 1) << NAMED_COUNT;

shift_runtime::(
    signed_value: i32,
    unsigned_value: u32,
    count_u8: u8,
    count_i64: i64
) -> void {
    signed_left: i32 =
        signed_value << count_u8;

    signed_right: i32 =
        signed_value >> count_i64;

    unsigned_left: u32 =
        unsigned_value << count_i64;

    unsigned_right: u32 =
        unsigned_value >> count_u8;

    /*
     * An untyped left literal defaults to i32 even though the count
     * is not known at compile time.
     */
    literal_left: i32 =
        1 << count_u8;
}
