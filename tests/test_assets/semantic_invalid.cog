bad_switch_float::(x: f64) -> i32 {
    switch x {
        case 1.0:
            return 1;

        default:
            return 0;
    }
}

bad_switch_enum_case_type::(c: Color) -> i32 {
    switch c {
        case 1:
            return 1;

        default:
            return 0;
    }
}

bad_switch_duplicate_enum::(c: Color) -> i32 {
    switch c {
        case Color.Red:
            return 1;

        case Color.Red:
            return 2;

        default:
            return 0;
    }
}

bad_switch_duplicate_default::(c: Color) -> i32 {
    switch c {
        case Color.Red:
            return 1;

        default:
            return 0;

        default:
            return 2;
    }
}

bad_switch_runtime_case::(x: i32, y: i32) -> i32 {
    switch x {
        case y:
            return 1;

        default:
            return 0;
    }
}

return_bad_empty::() -> i32 {
}

return_bad_if::(b: bool) -> i32 {
    if b {
        return 1;
    }
}

return_bad_switch_no_default::(c: Color) -> i32 {
    switch c {
        case Color.Red:
            return 1;
    }
}

return_bad_switch_case_falls_through::(c: Color) -> i32 {
    switch c {
        case Color.Red:
            return 1;

        default:
            x := 1;
    }
}

bad_cast_struct::() -> i32 {
    return cast(i32, Point {
        x = 1,
        y = 2,
    });
}

bad_cast_bool_to_int::() -> i32 {
    return cast(i32, true);
}

bad_cast_int_to_bool::() -> bool {
    return cast(bool, 1);
}

bad_cast_enum_to_float::() -> f64 {
    return cast(f64, Color.Red);
}

bad_cast_float_to_enum::() -> Color {
    return cast(Color, 1.5);
}

classify_color_missing_case::(c: Color) -> i32 {
    switch c {
        case Color.Red:
            return 1;

        case Color.Green:
            return 2;
    }
}

classify_color_case_falls_through::(c: Color) -> i32 {
    switch c {
        case Color.Red:
            return 1;

        case Color.Green:
            return 2;

        case Color.Blue: {
            x := 3;
        }
    }
}

