// This currently reports the resulting non-void function fallthrough
// rather than a dedicated non-exhaustive-switch diagnostic.

Color :: enum(u16) {
    Red,
    Green,
    Blue,
}

test::(color: Color) -> i32 {
    switch color {
        case Color.Red:
            return 1;

        case Color.Green:
            return 2;
    }
}
