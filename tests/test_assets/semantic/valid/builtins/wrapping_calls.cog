wrapping_calls::(
    signed_left: i8,
    signed_right: i8,
    unsigned_left: u64,
    unsigned_right: u64
) -> void {
    signed_add: i8 =
        wrapping_add(
            signed_left,
            signed_right
        );

    signed_sub: i8 =
        wrapping_sub(
            signed_left,
            signed_right
        );

    signed_mul: i8 =
        wrapping_mul(
            signed_left,
            signed_right
        );

    signed_neg: i8 =
        wrapping_neg(
            signed_left
        );

    unsigned_add: u64 =
        wrapping_add(
            unsigned_left,
            unsigned_right
        );

    unsigned_sub: u64 =
        wrapping_sub(
            unsigned_left,
            unsigned_right
        );

    unsigned_mul: u64 =
        wrapping_mul(
            unsigned_left,
            unsigned_right
        );

    unsigned_neg: u64 =
        wrapping_neg(
            unsigned_left
        );
}
