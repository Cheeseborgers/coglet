CONST_PI = 4;

BAD_CALL::some_func();
BAD_DIV::1 / 0;

bad_float_assignment: i64 = 3.14;

10 % 3.0;

bad_cmp_i32: i32 = 1;
bad_cmp_i64: i64 = 2;

bad_cmp_i32 == bad_cmp_i64;
bad_cmp_i32 < bad_cmp_i64;

true < false;
"hello" > "world";

bad_void_var: void;
bad_void_ptr: void*;
bad_void_array: void[4];
bad_void_const: void: 10;

bad_void_param::(value: void) {
}

bad_void_ptr_param::(value: void*) {
}

bad_void_return::() -> void* {
}

BadVoidStruct::struct {
    field: void;
}

BadVoidPointerStruct::struct {
    field: void*;
}

// new
BadBacking :: enum(f32) {
    A,
}

BadValue :: enum(u8) {
    A = 1.5,
}

DuplicateMember :: enum(u8) {
    A,
    A,
}

Color :: enum(u16) {
    Red,
    Green,
    Blue,
}

BadEnumMemberUse1: Color = Color;
BadEnumMemberUse2: Color = Color.Purple;

BadEnumMemberUse3: Color = 1;

OtherEnum :: enum(u16) {
    Red,
}

Color.Red == OtherEnum.Red;

Color.Red < Color.Blue;

Color.Red + Color.Blue;

Color :: enum(u16) {
    Red,
    Green,
    Blue,
}

BAD_COLOR_CONST: Color : 1;

BAD_COLOR_CONST_2 :: Color.Purple;

BAD_COLOR_ASSIGN: Color = 1;

bad_switch_float::(x: f64) -> i32 {
    switch x {
        case 1.0:
            return 1;

        default:
            return 0;
    }
}

bad_switch_enum_case_type::(c: Color) -> i32 {
    switch c {
        case 1:
            return 1;

        default:
            return 0;
    }
}

bad_switch_duplicate_enum::(c: Color) -> i32 {
    switch c {
        case Color.Red:
            return 1;

        case Color.Red:
            return 2;

        default:
            return 0;
    }
}

bad_switch_duplicate_default::(c: Color) -> i32 {
    switch c {
        case Color.Red:
            return 1;

        default:
            return 0;

        default:
            return 2;
    }
}

bad_switch_runtime_case::(x: i32, y: i32) -> i32 {
    switch x {
        case y:
            return 1;

        default:
            return 0;
    }
}
