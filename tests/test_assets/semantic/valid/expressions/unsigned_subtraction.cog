test_unsigned_subtraction::(
    left_u8: u8,
    right_u8: u8,
    left_u16: u16,
    right_u16: u16,
    left_u32: u32,
    right_u32: u32,
    left_u64: u64,
    right_u64: u64
) -> void {
    result_u8: u8 = left_u8 - right_u8;
    result_u16: u16 = left_u16 - right_u16;
    result_u32: u32 = left_u32 - right_u32;
    result_u64: u64 = left_u64 - right_u64;

    result_u8 -= right_u8;
    result_u16 -= right_u16;
    result_u32 -= right_u32;
    result_u64 -= right_u64;
}
