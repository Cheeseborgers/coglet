mutation_statements_are_valid :: () {
    x: i32 = 0;

    x = 1;
    x += 1;
    x -= 1;
    x *= 2;
    x /= 2;
    x %= 2;

    x++;
    x--;
    ++x;
    --x;
}

Point2 :: struct {
    x: i32;
}

mutation_targets_are_valid :: () {
    point := Point2 {
        x = 0,
    };

    values: i32[3] = [0, 0, 0];

    point.x = 1;
    point.x += 1;
    point.x++;

    values[0] = 1;
    values[1] += 1;
    values[2]++;
}

