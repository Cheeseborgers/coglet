favorite: Color = Color.Red;

other_color := Color.Green;

Color.Red == Color.Blue;
Color.Red != Color.Green;

use_color::(c: Color) -> Color {
    return Color.Blue;
}

result_color := use_color(Color.Red);

DEFAULT_COLOR :: Color.Red;

favorite1: Color = DEFAULT_COLOR;

EXPLICIT_COLOR: Color : Color.Blue;

other: Color = EXPLICIT_COLOR;

classify_color::(c: Color) -> i32 {
    switch c {
        case Color.Red:
            return 1;

        case Color.Green:
            return 2;

        case Color.Blue:
            return 3;

        default:
            return 0;
    }
}

classify_int::(x: i32) -> i32 {
    switch x {
        case 0:
            return 10;

        case 1:
            return 20;

        default:
            return 30;
    }
}

classify_bool::(b: bool) -> i32 {
    switch b {
        case true:
            return 1;

        case false:
            return 0;
    }
}

return_good_direct::() -> i32 {
    return 1;
}

return_good_if::(b: bool) -> i32 {
    if b {
        return 1;
    } else {
        return 2;
    }
}

return_good_switch::(c: Color) -> i32 {
    switch c {
        case Color.Red:
            return 1;

        default:
            return 0;
    }
}

