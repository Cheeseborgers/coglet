// ============================================================
// STRESS TEST: type_equal (struct + array element identity)
// ============================================================

use_point :: (p: Point) { }
use_point(origin);              // expect: pass, origin is Point

vec : Vec3;

int_arr : i32[5];
float_arr : f32[5];

take_int_arr :: (a: i32[5]) { }
take_int_arr(int_arr);           // expect: pass


// ============================================================
// STRESS TEST: initializer_compatible on assignment (not just decl)
// ============================================================

small : u8;
small = 5;                        // expect: pass, i32 literal -> u8 (int widening rule)

big : i64;
big = small;                      // expect: pass, u8 -> i64 (int/int compatible)

fptr : i32*;
fptr = 0;                         // expect: pass, 0 -> null pointer constant on assignment

wrong_ptr : i32*;

f : f32;
f = 3.14;                         // expect: pass, f64 literal -> f32 (float widening rule)

// ============================================================
// STRESS TEST: comparisons now return TYPE_BOOL
// ============================================================

is_greater := a > 1;              // expect: pass, bool inferred from comparison

flag : bool;
flag = a > 1;                     // expect: pass, comparison result -> bool var

// ============================================================
// STRESS TEST: if/while/for conditions must be bool
// ============================================================

if (a > 1) {                      // expect: pass, comparison is bool
    x = 1;
}

if (flag) {                       // expect: pass, flag is declared bool
    x = 1;
}

for flag {                        // expect: pass, bool condition
    break;
}

