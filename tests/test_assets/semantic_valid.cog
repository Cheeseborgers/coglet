classify_color::(c: Color) -> i32 {
    switch c {
        case Color.Red:
            return 1;

        case Color.Green:
            return 2;

        case Color.Blue:
            return 3;

        default:
            return 0;
    }
}

classify_int::(x: i32) -> i32 {
    switch x {
        case 0:
            return 10;

        case 1:
            return 20;

        default:
            return 30;
    }
}

classify_bool::(b: bool) -> i32 {
    switch b {
        case true:
            return 1;

        case false:
            return 0;
    }
}

