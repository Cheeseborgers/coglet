unreachable_after_return::() -> i32 {
    return 1;

    x := 2;
}

unreachable_after_if::(b: bool) -> i32 {
    if b {
        return 1;
    } else {
        return 2;
    }

    x := 3;
}

unreachable_after_switch::(c: Color) -> i32 {
    switch c {
        case Color.Red:
            return 1;

        default:
            return 0;
    }

    x := 4;
}

break;

continue;

break_invalid_function::() -> void {
    break;
}

continue_invalid_function::() -> void {
    continue;
}

